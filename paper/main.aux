\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Effect of the reranker on recall.} Recall@$k$ on HetDocQA dev, with all configurations sharing the same first-stage retriever. Adding the cross-encoder reranker raises the curve sharply, whereas adding the pool-expansion methods (RAPTOR, graph, and all combined) on top of the reranker changes it little.\relax }}{7}{figure.caption.28}\protected@file@percent }
\newlabel{fig:recall}{{3}{7}{\textbf {Effect of the reranker on recall.} Recall@$k$ on HetDocQA dev, with all configurations sharing the same first-stage retriever. Adding the cross-encoder reranker raises the curve sharply, whereas adding the pool-expansion methods (RAPTOR, graph, and all combined) on top of the reranker changes it little.\relax }{figure.caption.28}{}}
\newlabel{fig:recall@cref}{{[figure][3][]3}{[1][6][]7}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces \textbf  {Cross-benchmark significance.} \leavevmode {\color  {posg}{\fontfamily  {pzd}\fontencoding  {U}\fontseries  {m}\fontshape  {n}\selectfont  \char 51}}: improvement is significant after Holm--Bonferroni with consistent sign; \leavevmode {\color  {nullg}{\fontfamily  {pzd}\fontencoding  {U}\fontseries  {m}\fontshape  {n}\selectfont  \char 55}}: no reliable effect; \leavevmode {\color  {accent}$\circ $}: significant but sign-unstable across splits. The reranker helps on all three benchmarks, while the only novel method that reaches significance (SSCC) helps on HetDocQA alone.\relax }}{7}{table.caption.29}\protected@file@percent }
\newlabel{tab:survival}{{3}{7}{\textbf {Cross-benchmark significance.} \yes : improvement is significant after Holm--Bonferroni with consistent sign; \no : no reliable effect; \unstable : significant but sign-unstable across splits. The reranker helps on all three benchmarks, while the only novel method that reaches significance (SSCC) helps on HetDocQA alone.\relax }{table.caption.29}{}}
\newlabel{tab:survival@cref}{{[table][3][]3}{[1][6][]7}}
