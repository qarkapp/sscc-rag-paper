\@writefile{toc}{\contentsline {paragraph}{Why most methods do not help.}{7}{section*.33}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Routing degeneracy.} Per-query nearest-neighbor distances are nearly identical across queries (left); the entropy that EGR routes on sits at its theoretical ceiling with very little variance (center); and the per-query best strategy gives almost no advantage over a single fixed strategy (right). The signal a per-query router would need is not present.\relax }}{8}{figure.caption.30}\protected@file@percent }
\newlabel{fig:routing}{{4}{8}{\textbf {Routing degeneracy.} Per-query nearest-neighbor distances are nearly identical across queries (left); the entropy that EGR routes on sits at its theoretical ceiling with very little variance (center); and the per-query best strategy gives almost no advantage over a single fixed strategy (right). The signal a per-query router would need is not present.\relax }{figure.caption.30}{}}
\newlabel{fig:routing@cref}{{[figure][4][]4}{[1][7][]8}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {The gain is heterogeneity-specific.} Effect size (paired $\Delta $F1 with 95\% CI) of SSCC, HyDE, and RAPTOR as the benchmark moves from homogeneous multi-hop prose (MuSiQue) through single-document scientific prose (QASPER) to the heterogeneous collection (HetDocQA). SSCC's interval excludes zero only on HetDocQA.\relax }}{8}{figure.caption.31}\protected@file@percent }
\newlabel{fig:hetero}{{5}{8}{\textbf {The gain is heterogeneity-specific.} Effect size (paired $\Delta $F1 with 95\% CI) of SSCC, HyDE, and RAPTOR as the benchmark moves from homogeneous multi-hop prose (MuSiQue) through single-document scientific prose (QASPER) to the heterogeneous collection (HetDocQA). SSCC's interval excludes zero only on HetDocQA.\relax }{figure.caption.31}{}}
\newlabel{fig:hetero@cref}{{[figure][5][]5}{[1][7][]8}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Why one threshold fails.} Relevance-score distributions for relevant vs.\ non-relevant passages under the bi-encoder (left) and the cross-encoder (right) on HetDocQA. The two sources separate relevant from non-relevant at very different score ranges, so the per-source thresholds SSCC fits (dashed) differ substantially; a single global threshold cannot be right for both.\relax }}{8}{figure.caption.32}\protected@file@percent }
\newlabel{fig:sscc}{{6}{8}{\textbf {Why one threshold fails.} Relevance-score distributions for relevant vs.\ non-relevant passages under the bi-encoder (left) and the cross-encoder (right) on HetDocQA. The two sources separate relevant from non-relevant at very different score ranges, so the per-source thresholds SSCC fits (dashed) differ substantially; a single global threshold cannot be right for both.\relax }{figure.caption.32}{}}
\newlabel{fig:sscc@cref}{{[figure][6][]6}{[1][7][]8}}
