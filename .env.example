# Copy to .env and fill in. The .env file is git-ignored.

# oMLX runs locally but still requires an API key.
OMLX_API_KEY=
OMLX_BASE_URL=http://127.0.0.1:1234/v1

# Optional: stronger/closed models for generation and the faithfulness judge.
OPENROUTER_API_KEY=

# DeepSeek (OpenAI-compatible) for HetDocQA question generation.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
